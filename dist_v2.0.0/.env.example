# ─── 阿里云 · 云防火墙 ─────────────────────────────
# 注意：不再需要 ADDRESS_BOOK_UUID！
# 工具会自动按名称查找 "封禁ip地址簿_ipv4" 和 "封禁ip地址簿_ipv6"
# 如需自定义名称，可添加：
#   ALIBABACLOUD_ADDRESS_BOOK_IPV4_NAME=你的IPv4地址簿名
#   ALIBABACLOUD_ADDRESS_BOOK_IPV6_NAME=你的IPv6地址簿名
ALIBABACLOUD_ACCESS_KEY_ID=your_access_key_id
ALIBABACLOUD_ACCESS_KEY_SECRET=your_access_key_secret
ALIBABACLOUD_REGION=cn-hangzhou
# 可选：封禁描述（默认"攻防演练封禁"，可按需改为"重保封禁"等）
# ALIBABACLOUD_DESCRIPTION=攻防演练封禁

# ─── 腾讯云 · CVM安全组（自动管理）────────────────
# 注意：不再需要配置 SECURITY_GROUP_ID！
# 工具会自动查找或创建以 SG_NAME_PREFIX 命名的安全组
TENCENTCLOUD_SECRET_ID=your_secret_id
TENCENTCLOUD_SECRET_KEY=your_secret_key
TENCENTCLOUD_REGION=ap-guangzhou
# 可选：安全组名称前缀（默认"封禁ip-攻防演练-上海金融"）
# TENCENTCLOUD_SG_NAME_PREFIX=封禁ip-攻防演练-上海金融
# 可选：绑定实例ID列表（逗号分隔）
# TENCENTCLOUD_SG_INSTANCES=ins-f62w1qvw,ins-rmq29bks,ins-g8m28zyq,ins-nxj9slqu
# 可选：安全组规则上限（默认100）
# TENCENTCLOUD_SG_MAX_RULES=100
# 可选：封禁描述（默认"攻防演练封禁"）
# TENCENTCLOUD_DESCRIPTION=攻防演练封禁

# ─── 白名单 ────────────────────────────────────
# 该文件中的 IP/CIDR 不会被封禁，避免误封生产业务
# 每行一个 CIDR，# 开头为注释，空行忽略
# 默认: whitelist.txt（程序同级目录，可编辑后立即生效）
# WHITELIST_PATH=whitelist.txt
